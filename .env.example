# ============ LLM (ModelScope 推理 API · OpenAI 兼容) ============
# 同一个 ModelScope 令牌既用于 Studio 部署，也用于免费 LLM 推理
# 获取方式：https://modelscope.cn/my/myaccesstoken
MODELSCOPE_ACCESS_TOKEN=ms-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM 接入参数（已固定为 ModelScope 推理）
LLM_BASE_URL=https://api-inference.modelscope.cn/v1/
LLM_MODEL=deepseek-ai/DeepSeek-V3.2
LLM_FALLBACK_MODELS=deepseek-ai/DeepSeek-V3.2:DeepSeek,XiaomiMiMo/MiMo-V2.5-Pro

# ============ 嵌入模型 ============
# 本地推理，无需 key；首次启动自动下载约 100MB 到 data/models/
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
INTEGRATION_USE_LLM_JUDGE=0
INTEGRATION_AUTO_MERGE_SIM=0.92

# ============ 持久化路径 ============
DATABASE_URL=sqlite:///./data/db/app.db
CHROMA_PERSIST_DIR=./data/index/chroma

# ============ 开发模式 ============
DEBUG=1
